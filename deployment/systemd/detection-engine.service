[Unit]
Description=Zero-Day DoS Detection Engine
After=network.target

[Service]
Type=simple
User=nick
WorkingDirectory=/home/nick/Documents/Projects/Zion/zero-day-dos-detection-engine
ExecStart=/home/nick/.local/bin/streamlit run src/dashboard/app.py --server.port=8501 --server.address=0.0.0.0
Restart=on-failure
RestartSec=10
Environment=PYTHONPATH=/home/nick/Documents/Projects/Zion/zero-day-dos-detection-engine
Environment=LOG_LEVEL=INFO

[Install]
WantedBy=multi-user.target
